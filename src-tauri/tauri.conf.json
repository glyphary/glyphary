{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glyphary",
  "version": "0.1.0",
  "identifier": "com.local.glyphary",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Glyphary",
        "width": 1470,
        "height": 956,
        "minWidth": 760,
        "minHeight": 560,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Glyphary contributors",
    "copyright": "Copyright © 2026 Glyphary contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
